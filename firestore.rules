rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myAccount() {
      return get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data;
    }
    function isOwner() {
      return isSignedIn() && myAccount().role == 'owner';
    }
    function isActiveAdmin() {
      return isSignedIn() &&
        (myAccount().role == 'admin' || myAccount().role == 'owner') &&
        myAccount().banned != true;
    }

    // Public profile + role data. Anyone can read (needed to show creator
    // names/avatars/links). Only the account owner themself or the Owner
    // role can write.
    match /accounts/{uid} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isOwner());
      allow delete: if isOwner();
    }

    // Posts (Craftland maps). Public read. Only signed-in, non-banned
    // admins/owner can create. Only the post's own author or the Owner
    // can edit/delete it.
    match /posts/{postId} {
      allow read: if true;
      allow create: if isActiveAdmin();
      allow update: if isActiveAdmin() && (isOwner() || resource.data.authorId == request.auth.uid);
      allow delete: if isActiveAdmin() && (isOwner() || resource.data.authorId == request.auth.uid);
    }

    // Singleton documents: site-content/main and ad-settings/main
    match /site-content/{doc} {
      allow read: if true;
      allow write: if isOwner();
    }
    match /ad-settings/{doc} {
      allow read: if true;
      allow write: if isOwner();
    }
    match /branding/{doc} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}
